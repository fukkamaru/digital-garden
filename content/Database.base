views:
  - type: table
    name: 表
    order:
      - file.name
      - title
      - file.folder
      - type
      - file.ctime
      - file.mtime
      - file.links
      - file.tags
    sort:
      - property: file.folder
        direction: DESC
      - property: type
        direction: ASC
      - property: file.tags
        direction: DESC
    columnSize:
      file.name: 117
      file.ctime: 173
      file.links: 223
